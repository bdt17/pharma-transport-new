<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} - Thomas IT Pharma Transport" : "Pharma Transport SaaS - 21 CFR Part 11 Cold Chain" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="21 CFR Part 11 compliant pharma transport tracking. Real-time GPS, chain-of-custody, biologics cold chain.">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pharma Transport">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <!-- PWA manifest (uncomment if using PWA routes) -->
    <!-- <link rel="manifest" href="<%= pwa_manifest_path(format: :json) ?>"> -->

    <!-- Favicons -->
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Tailwind + Inter Font + Application CSS -->
    <%= stylesheet_link_tag "tailwind", "inter-font", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 min-h-screen antialiased font-sans">
    <!-- GLASS NAVBAR -->
    <nav class="navbar-glass sticky top-0 z-50 shadow-lg border-b border-white/50">
      <div class="max-w-7xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
          <!-- LOGO -->
          <div class="flex items-center space-x-3">
            <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-blue-600 rounded-2xl shadow-xl flex items-center justify-center">
              <span class="text-2xl font-bold text-white">🚚</span>
            </div>
            <div>
              <h1 class="text-2xl font-black bg-gradient-to-r from-gray-900 via-indigo-900 to-blue-900 bg-clip-text text-transparent">Thomas IT</h1>
              <p class="text-xs font-semibold text-indigo-600 uppercase tracking-wider">Pharma Transport</p>
            </div>
          </div>
          <!-- LIVE STATS -->
          <div class="hidden md:flex items-center space-x-6 text-sm font-semibold">
            <div class="flex items-center space-x-2 bg-emerald-100 px-3 py-1 rounded-xl">
              <div class="w-2.5 h-2.5 bg-emerald-500 rounded-full animate-pulse"></div>
              <span class="text-emerald-800">47 Trucks Live</span>
            </div>
            <span class="text-indigo-700 font-bold">21 CFR Part 11 ✓</span>
            <span class="bg-gradient-to-r from-emerald-500 to-green-600 text-white px-3 py-1 rounded-full text-xs shadow-md">Phase 11</span>
          </div>
          <!-- ACTIONS -->
          <div class="flex items-center space-x-3">
            <% if user_signed_in? %>
              <%= link_to "/dashboard",
                class: "px-6 py-2.5 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white rounded-xl font-semibold shadow-lg hover:shadow-xl transition-all duration-200" do %>
                📊 Dashboard
              <% end %>
              <%= button_to "/users/sign_out",
                method: :delete,
                class: "px-4 py-2.5 text-gray-700 hover:text-gray-900 font-semibold hover:bg-gray-100 rounded-xl transition-all duration-200" do %>
                Logout
              <% end %>
            <% else %>
              <%= link_to "/users/sign_in",
                class: "px-6 py-2.5 border-2 border-indigo-600 text-indigo-700 hover:bg-indigo-600 hover:text-white font-semibold rounded-xl transition-all duration-200 shadow-md hover:shadow-lg" do %>
                🔐 Login
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- FLASH MESSAGES -->
    <% if notice %>
      <div class="mx-6 mt-6 max-w-4xl mx-auto bg-emerald-100 border border-emerald-400 text-emerald-800 px-6 py-4 rounded-2xl shadow-lg">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="mx-6 mt-6 max-w-4xl mx-auto bg-rose-100 border border-rose-400 text-rose-800 px-6 py-4 rounded-2xl shadow-lg">
        <%= alert %>
      </div>
    <% end %>

    <!-- MAIN CONTENT -->
    <main class="max-w-7xl mx-auto px-6 pb-16">
      <%= yield %>
    </main>

    <!-- FOOTER -->
    <footer class="bg-gradient-to-r from-slate-900 via-indigo-900 to-slate-900 text-white/90 py-12 border-t border-white/10">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <div class="flex flex-wrap justify-center items-center gap-6 mb-6 text-sm font-medium">
          <span class="px-3 py-1 bg-emerald-800/30 rounded-full">🔬 21 CFR Part 11</span>
          <span class="px-3 py-1 bg-blue-800/30 rounded-full">🌡️ Cold Chain IoT</span>
          <span class="px-3 py-1 bg-slate-700/30 rounded-full">📍 Phoenix, AZ</span>
          <span class="px-3 py-1 bg-green-800/30 rounded-full">💳 Stripe Secure</span>
          <span class="px-3 py-1 bg-indigo-800/30 rounded-full">🛡️ 2FA Protected</span>
        </div>
        <div class="text-xs opacity-75">
          © 2026 Thomas Information Technology. Phase 11 Production SaaS.
        </div>
      </div>
    </footer>
  </body>
</html>
