<h1 class="text-2xl font-bold mb-4">Batches Dashboard</h1>

<% if @batches.any? %>
  <div class="overflow-x-auto">
    <table class="min-w-full bg-white border border-gray-200 rounded-lg">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs uppercase tracking-wider">Batch ID</th>
          <th class="px-4 py-2 text-left text-xs uppercase tracking-wider">Product</th>
          <th class="px-4 py-2 text-left text-xs uppercase tracking-wider">Status</th>
          <th class="px-4 py-2 text-left text-xs uppercase tracking-wider">Temp</th>
          <th class="px-4 py-2 text-left text-xs uppercase tracking-wider">Location</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @batches.each do |batch| %>
          <tr>
            <td class="px-4 py-2 text-sm font-mono"><%= batch.batch_id %></td>
            <td class="px-4 py-2 text-sm"><%= batch.product %></td>
            <td class="px-4 py-2 text-sm"><%= batch.status %></td>
            <td class="px-4 py-2 text-sm"><%= batch.temp %></td>
            <td class="px-4 py-2 text-sm"><%= batch.location %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="p-4 text-gray-700 bg-gray-100 rounded-lg">
    No batches found for this tenant.
  </div>
<% end %>
