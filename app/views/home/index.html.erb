<!DOCTYPE html>
<html>
<head>
  <title>Pharma Transport Dashboard</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  //fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Inter',sans-serif;background:#f7f9fc;color:#1a202c;line-height:1.6}
    .container{max-width:1200px;margin:0 auto;padding:2rem}
    .header{display:flex;justify-content:space-between;align-items:center;margin-bottom:3rem;border-bottom:1px solid #e2e8f0;padding-bottom:2rem}
    h1{font-size:2rem;font-weight:600;color:#2d3748;margin:0}
    .logout{background:#f56565;color:white;padding:0.75rem 1.5rem;border:none;border-radius:8px;font-weight:500;cursor:pointer;font-size:0.95rem;transition:background 0.2s}
    .logout:hover{background:#e53e3e}
    .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.5rem;margin-bottom:3rem}
    .stat-card{background:white;padding:1.5rem;border-radius:12px;box-shadow:0 4px 6px rgba(0,0,0,0.07);border-left:4px solid}
    .stat-card.green{border-left-color:#48bb78}
    .stat-card.blue{border-left-color:#4299e1}
    .stat-card.orange{border-left-color:#ed8936}
    .stat-number{font-size:2rem;font-weight:700;color:#2d3748}
    .stat-label{color:#718096;font-weight:500}
    .features{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem;margin-bottom:3rem}
    .feature{background:white;padding:2rem;border-radius:12px;box-shadow:0 4px 6px rgba(0,0,0,0.07);transition:transform 0.2s,box-shadow 0.2s}
    .feature:hover{transform:translateY(-4px);box-shadow:0 12px 24px rgba(0,0,0,0.1)}
    .feature-icon{font-size:3rem;margin-bottom:1rem;display:block}
    .feature h3{font-size:1.25rem;font-weight:600;color:#2d3748;margin-bottom:0.5rem}
    .feature p{color:#718096}
    .pdf-btn{display:inline-flex;align-items:center;background:#4299e1;color:white;padding:0.75rem 1.5rem;border:none;border-radius:8px;font-weight:500;text-decoration:none;font-size:0.95rem;transition:background 0.2s;margin-top:1rem}
    .pdf-btn:hover{background:#3182ce}
    .lead-section{background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;padding:3rem;border-radius:16px;text-align:center;margin-top:3rem}
    .lead-section h2{font-size:1.75rem;margin-bottom:1rem}
    .lead-section p{font-size:1.1rem;margin-bottom:2rem;opacity:0.9}
    .lead-form{max-width:500px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .lead-form input{padding:1rem;border:2px solid rgba(255,255,255,0.3);border-radius:8px;background:rgba(255,255,255,0.1);color:white;font-size:1rem}
    .lead-form input::placeholder{color:rgba(255,255,255,0.7)}
    .lead-submit{grid-column:1/-1;background:#48bb78;color:white;padding:1.125rem;border:none;border-radius:8px;font-size:1.1rem;font-weight:600;cursor:pointer;transition:background 0.2s}
    .lead-submit:hover{background:#38a169}
    @media(max-width:768px){.container{padding:1rem}.header flex-direction:column;gap:1rem;text-align:center}.lead-form{grid-template-columns:1fr}
  </style>
</head>
<body>
  <div class="container">
    <header class="header">
      <h1>🚚 Pharma Transport Dashboard</h1>
      <%= button_to "Logout", logout_path, method: :delete, class: "logout" %>
    </header>

    <div class="stats-grid">
      <div class="stat-card green">
        <div class="stat-number">✅ LIVE</div>
        <div class="stat-label">Production SaaS</div>
      </div>
      <div class="stat-card blue">
        <div class="stat-number">21 CFR</div>
        <div class="stat-label">Part 11 Compliance</div>
      </div>
      <div class="stat-card orange">
        <div class="stat-number">24/7</div>
        <div class="stat-label">Cold Chain</div>
      </div>
    </div>

    <div class="features">
      <div class="feature">
        <span class="feature-icon" style="color:#48bb78">📄</span>
        <h3>Chain of Custody PDF</h3>
        <p>21 CFR Part 11 compliant documentation</p>
        <%= link_to "Generate PDF", pdf_health_path, class: "pdf-btn" %>
      </div>
      
      <div class="feature">
        <span class="feature-icon" style="color:#4299e1">💳</span>
        <h3>Stripe Payments</h3>
        <p>Production ready billing system</p>
        <span class="pdf-btn" style="background:#718096;cursor:not-allowed">Coming Soon</span>
      </div>
      
      <div class="feature">
        <span class="feature-icon" style="color:#ed8936">📍</span>
        <h3>GPS Tracking</h3>
        <p>Real-time biologics monitoring</p>
        <span class="pdf-btn" style="background:#718096;cursor:not-allowed">Coming Soon</span>
      </div>
    </div>

    <div class="lead-section">
      <h2>💼 Pharma Logistics Demo</h2>
      <p>Track biologics shipments with full 21 CFR Part 11 compliance</p>
      <form action="https://formspree.io/f/xnjglwpe" method="POST" class="lead-form">
        <input type="email" name="email" placeholder="pharma@company.com" required>
        <input type="text" name="company" placeholder="Company" required>
        <button type="submit" class="lead-submit">Get Demo Access →</button>
      </form>
    </div>
  </div>
</body>
</html>
