<!DOCTYPE html>
<html>
<head>
  <title>Pharma Transport SaaS</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 min-h-screen">
  <!-- Navbar -->
  <nav class="bg-white/80 backdrop-blur-md shadow-lg sticky top-0 z-50 border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-6 py-4">
      <div class="flex justify-between items-center">
        <div class="text-2xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          🚚 Pharma Transport
        </div>
        <div class="space-x-4">
          <a href="/dashboard" class="text-blue-600 hover:text-blue-800 font-medium px-4 py-2 rounded-lg hover:bg-blue-50 transition-all">Dashboard</a>
          <a href="/login" class="bg-gradient-to-r from-blue-600 to-purple-600 text-white px-6 py-2 rounded-xl shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all">Login</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <main class="pt-24 pb-20 px-4 md:px-8">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-bold bg-gradient-to-r from-gray-900 via-slate-800 to-black bg-clip-text text-transparent mb-8">
        Enterprise Grade
      </h1>
      <p class="text-xl text-slate-700 mb-16 max-w-2xl mx-auto leading-relaxed">
        Real-time pharma logistics with 21 CFR Part 11 compliance. Track biologics cold chain end-to-end.
      </p>
    </div>

    <!-- Metrics Row -->
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 mb-20 px-4 text-center">
      <div class="bg-white/70 backdrop-blur-sm p-6 rounded-2xl shadow-xl border border-white/50">
        <div class="text-3xl font-bold text-blue-600">98%</div>
        <div class="text-sm font-medium text-slate-600 mt-1">Uptime</div>
      </div>
      <div class="bg-white/70 backdrop-blur-sm p-6 rounded-2xl shadow-xl border border-white/50">
        <div class="text-3xl font-bold text-emerald-600">1.247</div>
        <div class="text-sm font-medium text-slate-600 mt-1">Loads/Day</div>
      </div>
      <div class="bg-white/70 backdrop-blur-sm p-6 rounded-2xl shadow-xl border border-white/50">
        <div class="text-3xl font-bold text-purple-600">0.02%</div>
        <div class="text-sm font-medium text-slate-600 mt-1">Loss Rate</div>
      </div>
      <div class="bg-white/70 backdrop-blur-sm p-6 rounded-2xl shadow-xl border border-white/50">
        <div class="text-3xl font-bold text-orange-600">100%</div>
        <div class="text-sm font-medium text-slate-600 mt-1">Compliant</div>
      </div>
    </div>

    <!-- Feature Cards -->
    <div class="grid md:grid-cols-3 gap-8 max-w-7xl mx-auto px-4">
      <!-- Real-time GPS -->
      <div class="group bg-white rounded-3xl shadow-2xl hover:shadow-3xl p-10 border border-slate-100 hover:border-blue-200 transform hover:-translate-y-2 transition-all duration-300">
        <div class="w-20 h-20 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-2xl group-hover:scale-110 transition-transform">
          📍
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-4 text-center">Real-time GPS</h3>
        <p class="text-slate-600 leading-relaxed text-center mb-8">Queclink GV55 live tracking for cold chain biologics. 98% uptime SLA.</p>
        <button class="w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white py-4 px-8 rounded-2xl font-semibold shadow-xl hover:shadow-2xl transform hover:-translate-y-1 transition-all duration-300">
          View Demo
        </button>
      </div>

      <!-- Chain of Custody -->
      <div class="group bg-white rounded-3xl shadow-2xl hover:shadow-3xl p-10 border border-slate-100 hover:border-emerald-200 transform hover:-translate-y-2 transition-all duration-300">
        <div class="w-20 h-20 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-2xl group-hover:scale-110 transition-transform">
          🔗
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-4 text-center">Chain of Custody</h3>
        <p class="text-slate-600 leading-relaxed text-center mb-8">Immutable PDF logs with e-signatures. 21 CFR Part 11 ready.</p>
        <button class="w-full bg-gradient-to-r from-emerald-600 to-emerald-700 text-white py-4 px-8 rounded-2xl font-semibold shadow-xl hover:shadow-2xl transform hover:-translate-y-1 transition-all duration-300">
          Generate PDF
        </button>
      </div>

      <!-- 21 CFR Compliant -->
      <div class="group bg-white rounded-3xl shadow-2xl hover:shadow-3xl p-10 border border-slate-100 hover:border-purple-200 transform hover:-translate-y-2 transition-all duration-300">
        <div class="w-20 h-20 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-2xl group-hover:scale-110 transition-transform">
          📋
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-4 text-center">21 CFR Part 11</h3>
        <p class="text-slate-600 leading-relaxed text-center mb-8">FDA-validated platform for pharma transport compliance.</p>
        <button class="w-full bg-gradient-to-r from-purple-600 to-purple-700 text-white py-4 px-8 rounded-2xl font-semibold shadow-xl hover:shadow-2xl transform hover:-translate-y-1 transition-all duration-300">
          Compliance Audit
        </button>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-gradient-to-r from-slate-900 to-gray-900 text-white/90 py-12 mt-24 border-t-4 border-blue-600/30">
    <div class="max-w-7xl mx-auto px-8 text-center">
      © 2026 Thomas IT Network • Phoenix, AZ • Enterprise Pharma SaaS
    </div>
  </footer>
</body>
</html>
