<div class="min-h-screen bg-gradient-to-b from-gray-50 to-gray-100">
  <div class="container mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold text-indigo-700">
        Pharma Transport
      </h1>
      <div class="flex gap-3">
        <%= link_to "Login", new_user_session_path, class: "px-3 py-1 text-sm rounded bg-gray-200 hover:bg-gray-300 text-gray-800" %>
        <%= link_to "Register", new_user_registration_path, class: "px-3 py-1 text-sm rounded bg-indigo-600 hover:bg-indigo-700 text-white" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div class="bg-white rounded-lg shadow hover:shadow-md transition-shadow p-5">
        <h2 class="text-xl font-bold text-gray-800 mb-2">Cold Chain</h2>
        <p class="text-gray-600 mb-4">Temperature‑controlled pharma shipments.</p>
        <%= link_to "Dashboard →", dashboard_path, class: "inline-block text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
      </div>

      <div class="bg-white rounded-lg shadow hover:shadow-md transition-shadow p-5">
        <h2 class="text-xl font-bold text-gray-800 mb-2">Biologics</h2>
        <p class="text-gray-600 mb-4">Trackable biologic lots and batches.</p>
        <%= link_to "Browse batches →", batches_path, class: "inline-block text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
      </div>

      <div class="bg-white rounded-lg shadow hover:shadow-md transition-shadow p-5">
        <h2 class="text-xl font-bold text-gray-800 mb-2">GPS Tracking</h2>
        <p class="text-gray-600 mb-4">Real‑time GPS feeds and alerts.</p>
        <%= link_to "Track shipment →", "/api/gps", class: "inline-block text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
      </div>

      <div class="bg-white rounded-lg shadow hover:shadow-md transition-shadow p-5">
        <h2 class="text-xl font-bold text-gray-800 mb-2">CoC PDFs</h2>
        <p class="text-gray-600 mb-4">Chain‑of‑custody documentation.</p>
        <%= link_to "Open CoC PDF →",
            "/pdf/chain-of-custody?shipment_id=SHIP-20260320-001",
            class: "inline-block text-sm bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-1 px-3 rounded" %>
      </div>
    </div>

    <div class="flex justify-center">
      <%= link_to "📄 View sample CoC PDF",
          "/batches/123456/chain-of-custody.pdf",
          class: "inline-block px-4 py-2 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white text-sm font-semibold rounded shadow" %>
    </div>
  </div>
</div>
