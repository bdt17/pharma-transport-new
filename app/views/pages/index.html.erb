<div class="max-w-7xl mx-auto px-6 py-20">
  <!-- Hero -->
  <div class="grid md:grid-cols-2 gap-12 items-center mb-20">
    <div>
      <h1 class="text-5xl md:text-6xl font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent mb-6">
        💉 Pharma Transport SaaS
      </h1>
      <h2 class="text-2xl text-slate-600 mb-8 leading-relaxed">
        21 CFR Part 11 Compliant Cold Chain Tracking
      </h2>
      <div class="flex flex-col sm:flex-row gap-4">
        <%= link_to "🚀 Start Tracking Now", "#features", class: "bg-gradient-to-r from-blue-600 to-blue-700 text-white px-8 py-4 rounded-2xl font-semibold shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all" %>
        <%= link_to "📊 View Dashboard", batches_path, class: "border-2 border-blue-600 text-blue-600 px-8 py-4 rounded-2xl font-semibold hover:bg-blue-600 hover:text-white transition-all" %>
      </div>
    </div>
    <div class="text-center">
      <!-- SVG Cold Chain Truck (no external dependency) -->
      <div class="w-full h-72 bg-gradient-to-br from-blue-500 via-indigo-500 to-purple-600 rounded-3xl flex items-center justify-center shadow-2xl mx-auto">
        <div class="text-6xl">🚚</div>
        <span class="text-white text-2xl font-bold ml-4">Cold Chain</span>
      </div>
    </div>
  </div>

  <!-- Features -->
  <section id="features" class="py-20">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-slate-800 to-black bg-clip-text text-transparent">
        Enterprise Grade Features
      </h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Real-Time GPS -->
      <div class="group bg-white/50 backdrop-blur-sm rounded-3xl p-8 border border-white/50 shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 h-full">
        <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-2xl group-hover:scale-110 transition-transform">
          📍
        </div>
        <h5 class="text-xl font-bold text-slate-900 mb-4 text-center">Real-Time GPS</h5>
        <p class="text-slate-600 text-center leading-relaxed">Live location tracking with geofencing alerts</p>
      </div>

      <!-- Cold Chain -->
      <div class="group bg-white/50 backdrop-blur-sm rounded-3xl p-8 border border-white/50 shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 h-full">
        <div class="w-16 h-16 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-2xl group-hover:scale-110 transition-transform">
          🔬
        </div>
        <h5 class="text-xl font-bold text-slate-900 mb-4 text-center">Cold Chain Monitoring</h5>
        <p class="text-slate-600 text-center leading-relaxed">Temperature/humidity sensors + compliance reports</p>
      </div>

      <!-- 21 CFR -->
      <div class="group bg-white/50 backdrop-blur-sm rounded-3xl p-8 border border-white/50 shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 h-full">
        <div class="w-16 h-16 bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-2xl group-hover:scale-110 transition-transform">
          📜
        </div>
        <h5 class="text-xl font-bold text-slate-900 mb-4 text-center">21 CFR Part 11</h5>
        <p class="text-slate-600 text-center leading-relaxed">Audit trails, e‑signatures, record integrity</p>
      </div>

      <!-- Truck Rotation -->
      <div class="group bg-white/50 backdrop-blur-sm rounded-3xl p-8 border border-white/50 shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 h-full">
        <div class="w-16 h-16 bg-gradient-to-br from-orange-500 to-orange-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-2xl group-hover:scale-110 transition-transform">
          🔄
        </div>
        <h5 class="text-xl font-bold text-slate-900 mb-4 text-center">Cold Truck Rotation</h5>
        <p class="text-slate-600 text-center leading-relaxed">Track reusable trucks and shipping units</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 text-center">
    <div class="max-w-2xl mx-auto">
      <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">Ready to Go Live?</h3>
      <p class="text-xl text-slate-600 mb-8 leading-relaxed">
        Onboard your fleet and begin tracking cold‑chain shipments in under 10 minutes.
      </p>
      <%= link_to "👉 Get Started", new_user_registration_path, class: "inline-block bg-gradient-to-r from-blue-600 to-purple-600 text-white px-12 py-6 rounded-3xl text-xl font-semibold shadow-2xl hover:shadow-3xl hover:-translate-y-2 transition-all duration-300" %>
    </div>
  </section>
</div>
