    <p class="text-gray-600 mt-2">
      Track pharmaceutical shipments from origin to destination with full chain‑of‑custody PDFs.
    </p>

    <div class="mt-6 flex gap-3">
      <%= link_to "Login", new_user_session_path, class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow" %>
      <%= link_to "Register", new_user_registration_path, class: "px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold rounded-lg" %>
    </div>
  </div>
</div>
