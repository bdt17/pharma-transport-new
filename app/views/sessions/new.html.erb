<!-- Same login form but change password to: AdminPharma2026! -->
<div class="login-card">
  <h2>🔐 Pharma Transport Login</h2>
  
  <% if flash[:alert] %>
    <div class="alert"><%= flash[:alert] %></div>
  <% end %>
  
  <%= form_with url: login_path, local: true do |f| %>
    <div class="field">
      <%= f.label :email, "Email" %>
      <%= f.email_field :email, required: true, value: "admin@pharmatransport.com" %>
    </div>
    
    <div class="field">
      <%= f.label :password, "Password" %>
      <%= f.password_field :password, required: true, 
                          placeholder: "AdminPharma2026!", autocomplete: "current-password" %>
    </div>
    
    <%= f.submit "Login → MFA", class: "button" %>
  <% end %>
</div>
