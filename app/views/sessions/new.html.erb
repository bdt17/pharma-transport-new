<div style="max-width: 400px; margin: 100px auto; padding: 40px; background: white; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
  <h2 style="text-align: center; color: #1e40af; margin-bottom: 30px;">🔐 Pharma Transport Login</h2>
  
  <%= form_with url: session_path, local: true, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email, required: true, value: "admin@pharmatransport.com", 
                       class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    
    <div>
      <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, required: true, value: "pharma123",
                          class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>
    
    <%= f.submit "Login", class: "w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 font-medium" %>
  <% end %>
  
  <% if flash[:alert] %>
    <div style="color: #dc2626; background: #fef2f2; padding: 12px; border-radius: 6px; border-left: 4px solid #dc2626; margin-top: 20px;">
      <%= flash[:alert] %>
    </div>
  <% end %>
</div>
