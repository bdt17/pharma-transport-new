<div class="min-h-screen bg-gradient-to-b from-gray-50 to-gray-100">
  <div class="container mx-auto px-4 py-8">
    <!-- Header with back button -->
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-3">
        <%= link_to "← Back to Dashboard", dashboard_path, class: "inline-flex items-center px-3 py-1 text-sm bg-gray-200 hover:bg-gray-300 text-gray-800 rounded font-medium" %>
        <h1 class="text-3xl font-bold text-indigo-700">Batches</h1>
      </div>
      <div>
        <%= link_to "New batch", new_batch_path, class: "px-4 py-2 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white text-sm font-semibold rounded shadow" %>
      </div>
    </div>

    <p class="mb-6 text-sm text-green-600 font-medium" style="color: green"><%= notice %></p>

    <div id="batches" class="bg-white rounded-lg shadow-lg overflow-hidden">
      <% if @batches.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gradient-to-r from-indigo-600 to-purple-600">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider">
                  ID
                </th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider">
                  Drug / Lot
                </th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider">
                  Status
                </th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-white uppercase tracking-wider">
                  Actions
                </th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @batches.each do |batch| %>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                    <%= batch.id %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                    <%= batch.drug_name || "Insulin Lot" %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                      In Transit
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-2">
                    <%= link_to "View", batch, class: "text-indigo-600 hover:text-indigo-900" %>
                    <%= link_to "CoC PDF", batch_chain_of_custody_path(batch), 
                        class: "inline-flex items-center px-2 py-1 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white text-xs font-semibold rounded shadow transition-all duration-200", 
                        target: "_blank" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12">
          <p class="text-gray-500 text-lg mb-4">No batches yet</p>
          <%= link_to "Create your first batch", new_batch_path, class: "inline-block px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg shadow" %>
        </div>
      <% end %>
    </div>

    <!-- Pagination -->
    <div class="mt-8 flex justify-between items-center">
      <div class="text-sm text-gray-600">
        Showing <span class="font-medium">1-<%= @batches.size %></span> of <span class="font-medium"><%= @batches.total_count %></span> results
      </div>
      <div class="flex gap-2">
        <%= link_to "← Previous", "#", class: "px-3 py-1 bg-gray-200 hover:bg-gray-300 text-gray-800 rounded font-medium" %>
        <%= link_to "Next →", "#", class: "px-3 py-1 bg-indigo-600 hover:bg-indigo-700 text-white rounded font-medium" %>
      </div>
    </div>
  </div>
</div>
