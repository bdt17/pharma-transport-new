<%= content_for :title, "Pharma Transport Dashboard" %>

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-sea-serpent">
  <!-- Sidebar Navigation -->
  <div class="fixed inset-y-0 left-0 z-50 w-64 sidebar transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out lg:static lg:inset-0">
    <div class="flex items-center justify-center mt-8 mb-8 px-6">
      <h1 class="text-2xl font-bold pharma-gradient bg-clip-text text-transparent">PharmaTransport</h1>
    </div>
    <nav class="mt-10 px-4">
      <a href="/" class="flex items-center px-4 py-3 text-davy-grey bg-ocean-blue/10 rounded-xl mb-4 hover:bg-ocean-blue/20 transition-colors sidebar-link">
        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
        </svg>
        Dashboard
      </a>
      <a href="/batches" class="flex items-center px-4 py-3 text-davy-grey rounded-xl mb-4 hover:bg-silver/20 transition-colors sidebar-link">
        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
        </svg>
        Batches
      </a>
      <a href="/tracking" class="flex items-center px-4 py-3 text-davy-grey rounded-xl mb-4 hover:bg-silver/20 transition-colors sidebar-link">
        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        GPS Tracking
      </a>
      <a href="/reports" class="flex items-center px-4 py-3 text-davy-grey rounded-xl mb-4 hover:bg-silver/20 transition-colors sidebar-link">
        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
        Compliance Reports
      </a>
    </nav>
  </div>

  <!-- Mobile overlay -->
  <div id="mobile-overlay" class="fixed inset-0 z-40 bg-black bg-opacity-50 lg:hidden hidden"></div>

  <!-- Main Content -->
  <div class="lg:ml-64">
    <!-- Header -->
    <header class="navbar-glass sticky top-0 z-30">
      <div class="max-w-7xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg text-davy-grey hover:bg-silver/30 transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
            <h1 class="text-2xl font-bold text-davy-grey">Dashboard</h1>
          </div>
          <div class="flex items-center space-x-4">
            <div class="relative">
              <input type="text" placeholder="Search batches, trucks..." class="w-64 pl-10 pr-4 py-2 border border-silver rounded-xl focus:ring-2 focus:ring-ocean-blue focus:border-transparent">
              <svg class="absolute left-3 top-2.5 w-5 h-5 text-davy-grey" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
            <div class="flex items-center space-x-2">
              <button class="p-2 text-davy-grey hover:bg-silver/30 rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                </svg>
              </button>
              <div class="w-8 h-8 pharma-gradient rounded-full flex items-center justify-center text-white font-semibold">BT</div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main class="max-w-7xl mx-auto px-6 py-8">
      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="pharma-card p-6 hover:shadow-md transition-shadow">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-davy-grey">Active Batches</p>
              <p class="text-3xl font-bold text-ocean-blue mt-1"><%= @active_batches || 47 %></p>
            </div>
            <div class="p-3 bg-ocean-blue/10 rounded-xl">
              <svg class="w-8 h-8 text-ocean-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
              </svg>
            </div>
          </div>
        </div>

        <div class="pharma-card p-6 hover:shadow-md transition-shadow">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-davy-grey">Trucks Live</p>
              <p class="text-3xl font-bold text-ocean-blue mt-1"><%= @live_trucks || 12 %></p>
            </div>
            <div class="p-3 bg-emerald-100 rounded-xl">
              <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v1a2 2 0 01-2 2H4a2 2 0 01-2-2v-4a2 2 0 012 2v1a2 2 0 002 2h10a2 2 0 002-2v-1a2 2 0 012-2z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 16v-4m0 0V8M12 16h4m-4 0H8"></path>
              </svg>
            </div>
          </div>
        </div>

        <div class="pharma-card p-6 hover:shadow-md transition-shadow">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-davy-grey">Revenue</p>
              <p class="text-3xl font-bold text-ocean-blue mt-1">$<%= number_with_delimiter(@revenue || 4590) %></p>
            </div>
            <div class="p-3 bg-purple-100 rounded-xl">
              <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 14c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
            </div>
          </div>
        </div>

        <div class="pharma-card p-6 hover:shadow-md transition-shadow">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-davy-grey">Compliance</p>
              <p class="text-3xl font-bold text-ocean-blue mt-1">100%</p>
            </div>
            <div class="p-3 bg-orange-100 rounded-xl">
              <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 001.946.806 3.42 3.42 0 011.946-1.946 3.42 3.42 0 001.946-1.946 3.42 3.42 0 011.946-1.946 3.42 3.42 0 001.946-1.946 3.42 3.42 0 011.946-1.946 3.42 3.42 0 001.946-1.946 3.42 3.42 0 011.946-1.946 3.42 3.42 0 001.946-1.946 3.42 3.42 0 011.946-1.946 3.42 3.42 0 001.946-1.946 3.42 3.42 0 011.946-1.946"></path>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Batches & Quick Actions -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="pharma-card p-6">
          <h2 class="text-xl font-bold text-davy-grey mb-6">Recent Batches</h2>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
              <thead class="bg-slate-50">
                <tr>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-davy-grey uppercase tracking-wider">Batch ID</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-davy-grey uppercase tracking-wider">Status</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-davy-grey uppercase tracking-wider">Location</th>
                  <th class="px-6 py-4 text-left text-xs font-semibold text-davy-grey uppercase tracking-wider">Temp</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-slate-200">
                <% [[123456, 'In Transit', 'Phoenix, AZ', '2°C'], [789012, 'Delivered', 'Tucson, AZ', '4°C'], [345678, 'Pending', 'Loading', 'N/A']].each do |batch| %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-davy-grey">#<%= batch[0] %></td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class                      <span class="px-3 py-1 text-xs font-semibold rounded-full bg-ocean-blue/10 text-ocean-blue">
                        <%= batch[1] %>
                      </span>
                    </td>
                    <td class="px-6 py-4 text-sm text-davy-grey"><%= batch[2] %></td>
                    <td class="px-6 py-4 text-sm text-davy-grey"><%= batch[3] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="pharma-card p-6">
          <h2 class="text-xl font-bold text-davy-grey mb-6">Quick Actions</h2>
          <div class="space-y-4">
            <a href="/batches/new" class="block w-full bg-gradient-to-r btn-ocean text-white py-4 px-6 rounded-xl text-center font-semibold hover:shadow-lg transition-all">
              Create New Batch
            </a>
            <a href="/reports/compliance" class="block w-full bg-gradient-to-r from-emerald-500 to-emerald-600 text-white py-4 px-6 rounded-xl text-center font-semibold hover:from-emerald-600 hover:to-emerald-700 transition-all">
              Compliance Report (UI)
            </a>
            <a href="/tenants/new" class="block w-full bg-gradient-to-r from-purple-500 to-purple-600 text-white py-4 px-6 rounded-xl text-center font-semibold hover:from-purple-600 hover:to-purple-700 transition-all">
              Add New Tenant
            </a>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<!-- Mobile menu JS -->
<script>
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const sidebar = document.querySelector('.sidebar');
  const overlay = document.getElementById('mobile-overlay');

  if (mobileBtn && sidebar && overlay) {
    mobileBtn.addEventListener('click', () => {
      sidebar.classList.toggle('-translate-x-full');
      overlay.classList.toggle('hidden');
    });

    overlay.addEventListener('click', () => {
      sidebar.classList.add('-translate-x-full');
      overlay.classList.add('hidden');
    });
  }
</script>

<div class="compliance-section mt-6 p-6 bg-blue-50 rounded-lg">
  <h3 class="text-xl font-bold mb-4">🧪 Compliance Testing</h3>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <%= link_to "📋 Compliance UI", reports_compliance_path, class: "btn btn-primary p-4 text-center rounded-lg hover:bg-blue-600" %>
    <%= link_to "📄 Compliance PDF", reports_compliance_path(format: :pdf), class: "btn btn-success p-4 text-center rounded-lg hover:bg-green-600" %>
  </div>
</div>
