<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pharma Transport Clean" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pharma Transport Clean">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application" %>
  </head>
<div class="pdf-links btn-group fixed-bottom p-3" style="background: rgba(0,0,0,0.8);">
  <a href="/pdf/chain-of-custody?shipment_id=SHIP-20260319-001&format=coc" 
     class="btn btn-primary btn-sm me-2" target="_blank">📄 21 CFR COC</a>
  <a href="/pdf/chain-of-custody?shipment_id=SHIP-20260319-001&format=manifest" 
     class="btn btn-success btn-sm me-2" target="_blank">📋 Manifest</a>
  <a href="/pdf/chain-of-custody?shipment_id=SHIP-20260319-001&format=cert" 
     class="btn btn-info btn-sm" target="_blank">✅ Temp Cert</a>
</div>
  <body>
    <%= yield %>
  </body>
</html>
