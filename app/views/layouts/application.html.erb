<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} - Thomas IT Pharma Transport" : "Pharma Transport SaaS - 21 CFR Part 11 Cold Chain" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="21 CFR Part 11 compliant pharma transport tracking. Real-time GPS, chain-of-custody, biologics cold chain.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: { extend: { colors: { pharma: { 50: '#eff6ff', 500: '#3b82f6', 900: '#1e3a8a' } } } }
      }
    </script>
  </head>
  
  <body class="bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-100 min-h-screen antialiased font-sans">
    
    <!-- GLASSMORPHISM NAVBAR -->
    <nav class="bg-white/80 backdrop-blur-xl sticky top-0 z-50 shadow-lg border-b border-white/50 supports-[backdrop-filter:blur(20px)]:bg-white/90">
      <div class="max-w-7xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
          
          <!-- LOGO -->
          <div class="flex items-center space-x-3">
            <div class="w-12 h-12 bg-gradient-to-br from-indigo-500 to-blue-600 rounded-2xl shadow-xl flex items-center justify-center">
              <span class="text-2xl font-bold text-white">🚚</span>
            </div>
            <div>
              <h1 class="text-2xl font-black bg-gradient-to-r from-gray-900 via-indigo-900 to-blue-900 bg-clip-text text-transparent">
                Thomas IT
              </h1>
              <p class="text-xs font-semibold text-indigo-600 uppercase tracking-wider">Pharma Transport SaaS</p>
            </div>
          </div>
          
          <!-- STATS BAR -->
          <div class="hidden md:flex items-center space-x-8 text-sm">
            <div class="flex items-center space-x-1 text-emerald-700 font-bold">
              <span class="w-3 h-3 bg-emerald-500 rounded-full animate-pulse"></span>
              <span>47 Live Trucks</span>
            </div>
            <div class="text-gray-700">21 CFR Part 11 ✓</div>
            <div class="bg-gradient-to-r from-emerald-500 to-green-600 text-white px-3 py-1 rounded-full text-xs font-bold shadow-md">
              Phase 10 LIVE
            </div>
          </div>
          
          <!-- ACTIONS -->
          <div class="flex items-center space-x-4">
            <% if user_signed_in? %>
              <%= link_to "Dashboard", batches_path, class: "px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-300" %>
              <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "px-4 py-2 text-gray-700 hover:text-gray-900 font-medium" %>
            <% else %>
              <%= link_to "Login", new_user_session_path, class: "px-6 py-2 border border-indigo-600 text-indigo-600 hover:bg-indigo-600 hover:text-white font-semibold rounded-xl transition-all duration-300" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>
    
    <!-- FLASH MESSAGES -->
    <% if notice %>
      <div class="bg-emerald-100 border border-emerald-400 text-emerald-700 px-6 py-4 mx-6 mt-6 rounded-2xl shadow-lg max-w-4xl mx-auto">
        <%= notice %>
      </div>
    <% end %>
    
    <% if alert %>
      <div class="bg-rose-100 border border-rose-400 text-rose-700 px-6 py-4 mx-6 mt-6 rounded-2xl shadow-lg max-w-4xl mx-auto">
        <%= alert %>
      </div>
    <% end %>
    
    <!-- MAIN CONTENT -->
    <main class="max-w-7xl mx-auto px-6 pb-12">
      <%= yield %>
    </main>
    
    <!-- FOOTER -->
    <footer class="bg-gradient-to-r from-slate-900 to-indigo-900 text-white/90 py-12 mt-24">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <div class="flex flex-wrap justify-center items-center space-x-8 mb-8 text-sm">
          <span>🔬 21 CFR Part 11 Compliant</span>
          <span>🌡️ Cold Chain IoT</span>
          <span>📱 Phoenix, AZ</span>
          <span>🛡️ Stripe Secure</span>
        </div>
        <div class="border-t border-white/20 pt-8 text-xs">
          © 2026 Thomas Information Technology. Phase 10 Enterprise SaaS.
        </div>
      </div>
    </footer>
  </body>
</html>








