<!DOCTYPE html>
<html>
  <head>
    <title>Pharma Transport</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Tailwind CSS (from tailwindcss-rails gem) -->
