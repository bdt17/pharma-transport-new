<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} - Pharma Transport SaaS" : "Thomas IT | Pharma Transport SaaS" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pharma Transport SaaS">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    
    <!-- Bootstrap CSS for buttons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-light">
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);">
      <div class="container">
        <a class="navbar-brand fw-bold fs-3" href="/">
          💉 <span class="text-warning">Pharma Transport</span> SaaS
        </a>
        
        <div class="navbar-nav ms-auto">
          <!-- Auth Links -->
          <% if user_signed_in? %>
            <span class="navbar-text me-3 text-white">
              👤 <%= current_user.email %>
            </span>
            <%= link_to "📊 Dashboard", batches_path, class: "btn btn-outline-light btn-sm me-2" %>
            <%= button_to "🚪 Logout", destroy_user_session_path, 
                          method: :delete, 
                          class: "btn btn-outline-light btn-sm",
                          data: { turbo_confirm: "Log out?" } %>
          <% else %>
            <%= link_to "🔐 Login", new_user_session_path, class: "btn btn-outline-light btn-sm me-2" %>
            <%= link_to "📝 Sign Up", new_user_registration_path, class: "btn btn-warning btn-sm" %>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="container-fluid py-4">
      <%= yield %>
    </main>

    <!-- Fixed PDF Demo Buttons (for demo pages only) -->
    <% unless params[:controller] == "batches" && (action_name == "index" || action_name == "show") %>
      <div class="pdf-links btn-group fixed-bottom p-3" style="background: rgba(0,0,0,0.8);">
        <a href="/batches/123456/chain-of-custody.pdf" class="btn btn-primary btn-sm me-2" target="_blank">
          📄 21 CFR COC
        </a>
        <a href="/pay?batch_id=LOT-INSULIN-PROD" class="btn btn-success btn-sm me-2" target="_blank">
          💳 $50 Payment
        </a>
        <a href="/batches" class="btn btn-info btn-sm" target="_blank">
          📊 Dashboard
        </a>
      </div>
    <% end %>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
